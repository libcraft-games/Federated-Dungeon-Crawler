{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.quest.definition",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "A quest definition template. Servers define quests with objectives, prerequisites, and rewards.",
      "record": {
        "type": "object",
        "required": ["name", "description", "objectives"],
        "properties": {
          "name": { "type": "string", "maxLength": 128 },
          "description": { "type": "string", "maxLength": 4096 },
          "level": { "type": "integer", "minimum": 1, "description": "Minimum level to accept this quest" },
          "giver": { "type": "string", "description": "NPC definition ID that offers this quest" },
          "turnIn": { "type": "string", "description": "NPC definition ID to turn in quest (defaults to giver)" },
          "prerequisites": {
            "type": "array",
            "description": "Quest definition IDs that must be completed first",
            "items": { "type": "string" }
          },
          "objectives": {
            "type": "array",
            "description": "Ordered list of objectives to complete",
            "items": { "type": "ref", "ref": "#objective" }
          },
          "rewards": { "type": "ref", "ref": "#rewards" },
          "repeatable": { "type": "boolean", "description": "Whether this quest can be accepted again after completion" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "objective": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Objective type",
          "knownValues": ["kill", "collect", "talk", "visit", "deliver"]
        },
        "description": { "type": "string", "maxLength": 256 },
        "target": { "type": "string", "description": "Target ID (NPC def ID, item def ID, or room ID)" },
        "count": { "type": "integer", "minimum": 1, "description": "How many (default 1)" }
      }
    },
    "rewards": {
      "type": "object",
      "description": "Rewards granted on quest completion",
      "properties": {
        "xp": { "type": "integer" },
        "gold": { "type": "integer" },
        "items": {
          "type": "array",
          "description": "Item definition IDs granted as rewards",
          "items": { "type": "string" }
        }
      }
    }
  }
}
