{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.world.flag",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "Definition of a room flag. Servers publish these to describe custom flags they support.",
      "record": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 1024 },
          "effects": {
            "type": "array",
            "items": { "type": "ref", "ref": "#flagEffect" },
            "maxLength": 10
          }
        }
      }
    },
    "flagEffect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "The effect type, e.g. 'disable-combat', 'disable-magic', 'damage-over-time', 'heal-over-time', 'movement-penalty'"
        },
        "value": { "type": "integer" },
        "description": { "type": "string", "maxLength": 256 }
      }
    }
  }
}
