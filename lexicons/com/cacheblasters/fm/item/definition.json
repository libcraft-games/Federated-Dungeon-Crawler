{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.item.definition",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "An item definition template. Properties are open — servers define what properties items have via system.itemType records.",
      "record": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string", "maxLength": 128 },
          "type": { "type": "string", "description": "Item type ID referencing server's system.itemType definition" },
          "description": { "type": "string", "maxLength": 4096 },
          "weight": { "type": "integer" },
          "value": { "type": "integer" },
          "rarity": { "type": "string" },
          "levelRequired": { "type": "integer", "minimum": 1 },
          "stackable": { "type": "boolean" },
          "maxStack": { "type": "integer" },
          "properties": {
            "type": "unknown",
            "description": "Open map of property ID -> value, defined by the item's type schema"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
