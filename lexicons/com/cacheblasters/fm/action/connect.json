{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.action.connect",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Authenticate and enter the game world",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["characterDid"],
          "properties": {
            "characterDid": { "type": "string", "format": "did" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["sessionId", "websocketUrl", "spawnRoom"],
          "properties": {
            "sessionId": { "type": "string" },
            "websocketUrl": { "type": "string", "format": "uri" },
            "spawnRoom": { "type": "string" },
            "serverInfo": { "type": "unknown" },
            "characterState": { "type": "unknown" }
          }
        }
      }
    }
  }
}
