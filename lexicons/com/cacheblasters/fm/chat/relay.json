{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.chat.relay",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Relay a chat message to a player on this server from another federated server",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["senderName", "senderDid", "recipientName", "message", "sourceServer"],
          "properties": {
            "senderName": {
              "type": "string",
              "maxLength": 64,
              "description": "Character name of the sender"
            },
            "senderDid": {
              "type": "string",
              "format": "did",
              "description": "DID of the sending player"
            },
            "recipientName": {
              "type": "string",
              "maxLength": 64,
              "description": "Character name of the recipient on this server"
            },
            "message": {
              "type": "string",
              "maxLength": 2000,
              "description": "The chat message content"
            },
            "sourceServer": {
              "type": "string",
              "format": "did",
              "description": "DID of the originating server"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["delivered"],
          "properties": {
            "delivered": {
              "type": "boolean",
              "description": "Whether the message was delivered to the recipient"
            },
            "reason": {
              "type": "string",
              "description": "Reason for non-delivery"
            }
          }
        }
      }
    }
  }
}
