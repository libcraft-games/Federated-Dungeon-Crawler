{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.system.spell",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "Defines a spell. Record key is the spell ID (e.g. 'fireball', 'heal').",
      "record": {
        "type": "object",
        "required": ["name", "description", "mpCost", "attribute", "effect", "power", "target"],
        "properties": {
          "name": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 2048 },
          "mpCost": { "type": "integer", "minimum": 0 },
          "apCost": { "type": "integer", "minimum": 0, "description": "Action point cost (defaults to 2 if unset)" },
          "levelRequired": { "type": "integer", "minimum": 1 },
          "attribute": { "type": "string", "description": "Attribute ID used for spell power scaling (e.g. 'int', 'wis')" },
          "effect": {
            "type": "string",
            "knownValues": ["damage", "heal", "buff", "debuff"]
          },
          "power": { "type": "integer", "description": "Base power before attribute scaling" },
          "dice": { "type": "string", "description": "Dice notation for variable component, e.g. '2d6'" },
          "target": {
            "type": "string",
            "knownValues": ["enemy", "self", "ally"]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
