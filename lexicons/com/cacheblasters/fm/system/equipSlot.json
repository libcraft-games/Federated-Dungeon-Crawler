{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.system.equipSlot",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "Defines an equipment slot. Record key is the slot ID (e.g. 'mainHand', 'implant-cranial').",
      "record": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 512 },
          "category": { "type": "string", "description": "Grouping, e.g. 'armor', 'weapon', 'accessory'" },
          "maxItems": { "type": "integer", "minimum": 1, "description": "How many items can occupy this slot (default 1)" },
          "aliases": {
            "type": "array",
            "description": "Alternative names players can use to refer to this slot",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
