{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.system.itemType",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "Defines an item type and what properties items of this type can have. Record key is the type ID (e.g. 'weapon', 'implant', 'potion').",
      "record": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 512 },
          "properties": {
            "type": "array",
            "items": { "type": "ref", "ref": "#propertyDef" },
            "description": "Properties that items of this type can have"
          },
          "stackable": { "type": "boolean" },
          "equippable": { "type": "boolean" },
          "equipSlots": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Which equipment slot IDs this type can go in"
          }
        }
      }
    },
    "propertyDef": {
      "type": "object",
      "required": ["id", "name", "valueType"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "maxLength": 64 },
        "valueType": { "type": "string", "knownValues": ["integer", "number", "string", "boolean"] },
        "description": { "type": "string", "maxLength": 256 }
      }
    }
  }
}
