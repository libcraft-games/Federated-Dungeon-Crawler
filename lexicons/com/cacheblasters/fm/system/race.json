{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.system.race",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "Defines a character race/species. Record key is the race ID.",
      "record": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 2048 },
          "attributeBonuses": {
            "type": "unknown",
            "description": "Map of attribute ID -> bonus value, e.g. { 'str': 2, 'con': 1 }"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
