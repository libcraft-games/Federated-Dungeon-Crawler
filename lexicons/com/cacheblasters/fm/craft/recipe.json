{
  "lexicon": 1,
  "id": "com.cacheblasters.fm.craft.recipe",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "A crafting recipe defining ingredients, station requirement, and output.",
      "record": {
        "type": "object",
        "required": ["name", "ingredients", "output"],
        "properties": {
          "name": { "type": "string", "maxLength": 128 },
          "description": { "type": "string", "maxLength": 1024 },
          "station": {
            "type": "string",
            "description": "Required crafting station type (e.g. 'campfire', 'forge', 'alchemy'). Omit for hand-crafting."
          },
          "levelRequired": { "type": "integer", "minimum": 1 },
          "ingredients": {
            "type": "array",
            "items": { "type": "ref", "ref": "#ingredient" },
            "maxLength": 10
          },
          "output": { "type": "ref", "ref": "#output" },
          "successChance": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Base success percentage. Defaults to 100 if omitted."
          },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ingredient": {
      "type": "object",
      "required": ["itemId", "count"],
      "properties": {
        "itemId": { "type": "string", "description": "Item definition ID" },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "output": {
      "type": "object",
      "required": ["itemId", "count"],
      "properties": {
        "itemId": { "type": "string", "description": "Item definition ID for the crafted result" },
        "count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
